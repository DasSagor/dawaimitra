# ================================================
# DawaiMitra — Environment Variables
# Copy this file to .env.local and fill in values
# ================================================

# Groq API Key (server-side only — for Llama Vision OCR)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (server-side only — for drug interaction reasoning)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration (public keys — safe to expose in browser)
# Get from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (server-side only — for writes)
# Optional: if not set, falls back to anon key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
